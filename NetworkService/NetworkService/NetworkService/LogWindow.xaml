<Window x:Class="NetworkService.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usage log"
        Width="1440"
        Height="810"
        MinWidth="1280"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="#E8E8E8"
        FontFamily="Segoe UI"
        FontSize="16"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="2"
            BorderBrush="#222222"
            BorderThickness="1"
            Background="#E8E8E8">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="#6E6E6E"
                    BorderThickness="1"
                    CornerRadius="2"
                    Background="#E1E1E1"
                    MouseLeftButtonDown="WindowHeader_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◷"
                                   FontSize="25"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="▥"
                                   FontSize="27"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Network Service"
                                       FontWeight="Bold"
                                       FontSize="25"
                                       LineHeight="26"/>
                            <TextBlock Text="DISPATCHER CONTROL SYSTEM"
                                       FontSize="14"
                                       LineHeight="15"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Command="{Binding RefreshLogCommand}"
                                Width="104"
                                Height="37"
                                Padding="0"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="↻"
                                           FontSize="17"
                                           LineHeight="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="Refresh"
                                           FontSize="16"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding BackCommand}"
                                Width="82"
                                Height="37"
                                Padding="0"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="↵"
                                           FontSize="17"
                                           LineHeight="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="Back"
                                           FontSize="16"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ToggleFullscreenCommand}"
                                Width="38"
                                Height="37"
                                Padding="0"
                                Margin="0,0,12,0">
                            <TextBlock Text="⛶"
                                       FontSize="18"
                                       LineHeight="20"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>

                        <Button Command="{Binding CloseApplicationCommand}"
                                Width="40"
                                Height="37"
                                Padding="0">
                            <TextBlock Text="⏻"
                                       FontSize="20"
                                       LineHeight="22"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    BorderBrush="#6E6E6E"
                    BorderThickness="1"
                    CornerRadius="2"
                    Background="#EEEEEE">
                <Grid Margin="15,10,15,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▧"
                                   FontSize="22"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Usage log"
                                   FontWeight="SemiBold"
                                   FontSize="23"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="{Binding LogFilePathText}"
                               FontSize="15"
                               Foreground="#555555"
                               VerticalAlignment="Center"/>

                    <Border Grid.Row="2"
                            BorderBrush="#777777"
                            BorderThickness="1"
                            Background="#E3E3E3"
                            Padding="8">
                        <ListBox ItemsSource="{Binding LogEntries}"
                                 BorderBrush="#777777"
                                 BorderThickness="1"
                                 Background="#E3E3E3"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#999999"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▧"
                                                       FontSize="17"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="16"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
