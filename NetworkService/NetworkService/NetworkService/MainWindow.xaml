<Window x:Class="NetworkService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Network Service"
        Width="1440"
        Height="810"
        MinWidth="1280"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#E8E8E8"
        FontFamily="Segoe UI"
        FontSize="16"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="PanelDarkBrush" Color="#D7D7D7"/>
        <SolidColorBrush x:Key="BorderBrushMain" Color="#6E6E6E"/>
        <SolidColorBrush x:Key="TextBrushMain" Color="#111111"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#777777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Background" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#777777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid VerticalAlignment="Center"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="14"
                                  Height="14"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center">
                                <Ellipse x:Name="OuterCircle"
                                         Stroke="#333333"
                                         Fill="Transparent"
                                         StrokeThickness="1"/>
                                <Ellipse x:Name="InnerCircle"
                                         Width="6"
                                         Height="6"
                                         Fill="#333333"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <ContentPresenter Grid.Column="1"
                                              Margin="4,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterCircle" Property="Stroke" Value="#999999"/>
                                <Setter TargetName="InnerCircle" Property="Fill" Value="#999999"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid VerticalAlignment="Center"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBorder"
                                    Width="14"
                                    Height="14"
                                    BorderBrush="#333333"
                                    BorderThickness="1"
                                    Background="Transparent"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="CheckMark"
                                           Text="✓"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           LineHeight="12"
                                           Visibility="Collapsed"/>
                            </Border>

                            <ContentPresenter Grid.Column="1"
                                              Margin="5,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              RecognizesAccessKey="True"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#999999"/>
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Height" Value="37"/>
            <Setter Property="MinWidth" Value="260"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#777777"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="Background" Value="#E5E5E5"/>
            <Setter Property="RowBackground" Value="#E5E5E5"/>
            <Setter Property="AlternatingRowBackground" Value="#DCDCDC"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="NetworkGridDropSlotStyle" TargetType="Border">
            <Setter Property="Margin" Value="7"/>
            <Setter Property="Background" Value="#E9E9E9"/>
            <Setter Property="BorderBrush" Value="#9A9A9A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <DataTemplate x:Key="EntityTreeItemTemplate">
            <Border Height="34"
                    BorderBrush="#777777"
                    BorderThickness="0,0,0,1"
                    Background="#E4E4E4"
                    Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding LastMeasure, StringFormat=Last: {0:F2} kWh}"
                                   FontSize="11"
                                   Foreground="#555555"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="≡"
                               Cursor="Hand"
                               ToolTip="Drag entity to network grid"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="22"
                               FontWeight="Bold"
                               MouseLeftButtonDown="AvailableEntityDragHandle_MouseLeftButtonDown"
                               MouseMove="DragHandle_MouseMove"
                               MouseLeftButtonUp="DragHandle_MouseLeftButtonUp"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NetworkGridSlotTemplate">
            <Border Style="{StaticResource NetworkGridDropSlotStyle}"
                    Drop="NetworkGridSlot_Drop"
                    DragOver="NetworkGridSlot_DragOver"
                    DragEnter="NetworkGridSlot_DragOver">
                <Grid Background="#E9E9E9">
                    <Rectangle Stroke="#9A9A9A"
                               StrokeThickness="2"
                               StrokeDashArray="4 4"
                               Fill="#E9E9E9">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEntity}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEntity}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="DRAG ENTITY HERE"
                                   Foreground="#9A9A9A"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SlotNumberText}"
                                   Foreground="#9A9A9A"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Width="150"
                            Height="104"
                            Background="#EFEFEF"
                            CornerRadius="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="8"
                            MouseLeftButtonDown="PlacedEntityCard_MouseLeftButtonDown"
                            ToolTip="Click two placed entities to connect them with a line">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="BorderBrush" Value="#555555"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasEntity}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelectedForConnection}" Value="True">
                                        <Setter Property="BorderBrush" Value="#111111"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Entity.IsLastMeasureInvalid}" Value="True">
                                        <Setter Property="BorderBrush" Value="#C62828"/>
                                        <Setter Property="BorderThickness" Value="3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="23"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="31"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="3"
                                       Text="{Binding Entity.Name}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>

                            <TextBlock Grid.Row="1"
                                       Grid.ColumnSpan="3"
                                       Text="{Binding Entity.LastMeasureText}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Row="2"
                                    Grid.Column="0"
                                    Width="27"
                                    Height="24"
                                    BorderBrush="#333333"
                                    BorderThickness="1.4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom">
                                <TextBlock Text="⌁"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding Entity.MeasureStatusText}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#333333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Entity.IsLastMeasureInvalid}" Value="True">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    Width="27"
                                    Height="27"
                                    CornerRadius="14"
                                    BorderBrush="#333333"
                                    BorderThickness="1.4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#333333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Entity.IsLastMeasureInvalid}" Value="True">
                                                <Setter Property="BorderBrush" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Entity.StatusIconText}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Entity.IsLastMeasureInvalid}" Value="True">
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <TextBlock Grid.Column="2"
                                       Text="≡"
                                       Cursor="Hand"
                                       ToolTip="Move entity"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       MouseLeftButtonDown="PlacedEntityDragHandle_MouseLeftButtonDown"
                                       MouseMove="DragHandle_MouseMove"
                                       MouseLeftButtonUp="DragHandle_MouseLeftButtonUp"/>

                            <Button Grid.Row="2"
                                    Grid.ColumnSpan="3"
                                    Command="{Binding DataContext.NetworkDisplay.RemoveEntityFromSlotCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Width="18"
                                    Height="18"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ToolTip="Remove entity from grid and return it to list">
                                <TextBlock Text="×"
                                           FontSize="13"
                                           FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EntityTypeTemplate">
            <Expander IsExpanded="{Binding IsExpanded}"
                      Background="#CFCFCF"
                      BorderBrush="#777777"
                      BorderThickness="1"
                      Margin="0,0,0,12">
                <Expander.Header>
                    <TextBlock Text="{Binding Name}" FontSize="17"/>
                </Expander.Header>
                <ItemsControl ItemsSource="{Binding Entities}"
                              ItemTemplate="{StaticResource EntityTreeItemTemplate}"/>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="GraphPointTemplate">
            <Canvas Width="1" Height="1">
                <Line X1="{Binding X}"
                      Y1="250"
                      X2="{Binding X}"
                      Y2="{Binding CenterY}"
                      Stroke="#999999"
                      StrokeThickness="1"
                      StrokeDashArray="5 5"/>
                <Ellipse Width="{Binding CircleSize}"
                         Height="{Binding CircleSize}"
                         Fill="{Binding CircleFill}"
                         Stroke="#555555"
                         StrokeThickness="1"
                         Canvas.Left="{Binding CircleLeft}"
                         Canvas.Top="{Binding CircleTop}"/>
                <TextBlock Text="{Binding ValueText}"
                           FontSize="14"
                           Canvas.Left="{Binding LabelLeft}"
                           Canvas.Top="{Binding LabelTop}"/>
                <TextBlock Text="{Binding TimeText}"
                           FontSize="14"
                           Canvas.Left="{Binding TimeLeft}"
                           Canvas.Top="260"/>
                <TextBlock Text="{Binding DateText}"
                           FontSize="14"
                           Canvas.Left="{Binding DateLeft}"
                           Canvas.Top="278"/>
            </Canvas>
        </DataTemplate>
    </Window.Resources>

    <Border Margin="2"
            BorderBrush="#222222"
            BorderThickness="1"
            Background="{StaticResource BackgroundBrush}">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BorderBrushMain}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Background="#E1E1E1"
                    MouseLeftButtonDown="WindowHeader_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◷"
                                   FontSize="25"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="▥"
                                   FontSize="27"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="Network Service"
                                       FontWeight="Bold"
                                       FontSize="25"
                                       LineHeight="26"/>
                            <TextBlock Text="DISPEČERSKI SISTEM"
                                       FontSize="14"
                                       LineHeight="15"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Command="{Binding OpenUsageLogCommand}"
                                Height="37"
                                MinWidth="72"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="◷"
                                           FontSize="17"
                                           LineHeight="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="Log"
                                           FontSize="16"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ToggleFullscreenCommand}"
                                Width="38"
                                MinWidth="38"
                                Height="37"
                                Padding="0"
                                Margin="0,0,12,0">
                            <TextBlock Text="⛶"
                                       FontSize="18"
                                       LineHeight="20"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>

                        <Button Command="{Binding CloseApplicationCommand}"
                                Width="40"
                                MinWidth="40"
                                Height="37"
                                Padding="0">
                            <TextBlock Text="⏻"
                                       FontSize="20"
                                       LineHeight="22"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="61*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="39*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="{StaticResource BorderBrushMain}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Background="{StaticResource PanelBrush}">
                    <Grid Margin="14,10,14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="31"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⌘"
                                       FontSize="23"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Network Display View"
                                       FontWeight="SemiBold"
                                       FontSize="23"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="245"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource BorderBrushMain}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Background="#E9E9E9">
                                <Grid Margin="11">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="☰"
                                                   FontSize="16"
                                                   Margin="0,0,28,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="List of entities"
                                                   FontWeight="SemiBold"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding NetworkDisplay.AvailableEntityTypes}"
                                                      ItemTemplate="{StaticResource EntityTypeTemplate}"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    BorderBrush="{StaticResource BorderBrushMain}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Background="#E9E9E9">
                                <Grid Margin="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="43"/>
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <TextBlock Text="⠿"
                                                   FontSize="21"
                                                   HorizontalAlignment="Left"/>
                                        <TextBlock Text="Network grid"
                                                   FontWeight="SemiBold"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <ItemsControl x:Name="NetworkGridItemsControl"
                                                      ItemsSource="{Binding NetworkDisplay.DropSlots}"
                                                      ItemTemplate="{StaticResource NetworkGridSlotTemplate}"
                                                      Loaded="NetworkGridItemsControl_Loaded">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="4"
                                                                 Columns="3"
                                                                 Margin="0"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>

                                        <Canvas x:Name="ConnectionCanvas"
                                                IsHitTestVisible="False"
                                                Panel.ZIndex="10"/>
                                    </Grid>

                                    <Button Command="{Binding NetworkDisplay.AutoPlaceEntitiesCommand}"
                                            Grid.Row="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            MinWidth="175"
                                            Height="32">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <TextBlock Text="↯"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,4,0"/>
                                            <TextBlock Text="Auto place entities"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0"/>
                                            <TextBlock Text="CTRL + P"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        BorderBrush="{StaticResource BorderBrushMain}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Background="{StaticResource PanelBrush}">
                    <TabControl SelectedIndex="{Binding SelectedRightTabIndex}">
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="♙"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                    <TextBlock Text="Network Entities"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                    <TextBlock Text="CTRL + 1"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </TabItem.Header>

                            <Grid Margin="25,13,25,22">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="33"/>
                                    <RowDefinition Height="47"/>
                                    <RowDefinition Height="33"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="13"/>
                                    <RowDefinition Height="167"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <TextBlock Text="⊞"
                                               FontSize="23"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="ADD NEW ENTITY"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="1"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Background="#DADADA"
                                        Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Entity type:"
                                                   FontWeight="SemiBold"
                                                   FontSize="18"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>

                                        <ComboBox Grid.Column="1"
                                                  SelectedItem="{Binding NetworkEntities.SelectedEntityType}">
                                            <sys:String>Interval Meter</sys:String>
                                            <sys:String>Smart Meter</sys:String>
                                        </ComboBox>

                                        <Button Grid.Column="3"
                                                Command="{Binding NetworkEntities.OpenAddEntityDialogCommand}"
                                                MinWidth="120"
                                                Height="29">
                                            <TextBlock Text="Add entity"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <TextBlock Text="▦"
                                               FontSize="23"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock Text="ENTITY TABLE"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="3"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="1" Margin="0,0,0,37">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="44"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid ItemsSource="{Binding NetworkEntities.Entities}"
                                                  SelectedItem="{Binding NetworkEntities.SelectedEntity}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID"
                                                                    Binding="{Binding Id}"
                                                                    Width="60">
                                                    <DataGridTextColumn.HeaderStyle>
                                                        <Style TargetType="DataGridColumnHeader">
                                                            <Setter Property="FontSize" Value="14"/>
                                                        </Style>
                                                    </DataGridTextColumn.HeaderStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="NAME"
                                                                    Binding="{Binding Name}"
                                                                    Width="*">
                                                    <DataGridTextColumn.HeaderStyle>
                                                        <Style TargetType="DataGridColumnHeader">
                                                            <Setter Property="FontSize" Value="14"/>
                                                        </Style>
                                                    </DataGridTextColumn.HeaderStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="TYPE"
                                                                    Binding="{Binding TypeName}"
                                                                    Width="*">
                                                    <DataGridTextColumn.HeaderStyle>
                                                        <Style TargetType="DataGridColumnHeader">
                                                            <Setter Property="FontSize" Value="14"/>
                                                        </Style>
                                                    </DataGridTextColumn.HeaderStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="LAST MEASURE"
                                                                    Binding="{Binding LastMeasure}"
                                                                    Width="*">
                                                    <DataGridTextColumn.HeaderStyle>
                                                        <Style TargetType="DataGridColumnHeader">
                                                            <Setter Property="FontSize" Value="14"/>
                                                        </Style>
                                                    </DataGridTextColumn.HeaderStyle>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Border Grid.Row="1"
                                                Background="#CFCFCF"
                                                BorderBrush="{StaticResource BorderBrushMain}"
                                                BorderThickness="0,1,0,0">
                                            <Button Command="{Binding NetworkEntities.RemoveSelectedEntityCommand}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    MinWidth="220"
                                                    Height="31">
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="Remove selected entities"
                                                           FontSize="16"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,16,0"/>
                                                    <TextBlock Text="DEL"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="3"
                                        BorderBrush="{StaticResource BorderBrushMain}"
                                        BorderThickness="1"
                                        Background="#DADADA"
                                        CornerRadius="2"
                                        Padding="12" Margin="0,317,0,0" Grid.RowSpan="3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="39"/>
                                            <RowDefinition Height="33"/>
                                            <RowDefinition Height="39"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <TextBlock Text="⌯"
                                                       FontSize="23"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock Text="FILTER/SEARCH"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="125"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Entity type:"
                                                       FontWeight="SemiBold"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>

                                            <ComboBox Grid.Column="1"
                                                      SelectedItem="{Binding NetworkEntities.Filter.SelectedType}">
                                                <sys:String>All</sys:String>
                                                <sys:String>Interval Meter</sys:String>
                                                <sys:String>Smart Meter</sys:String>
                                            </ComboBox>

                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">

                                                <RadioButton GroupName="FilterOperator"
                                                             IsChecked="{Binding NetworkEntities.Filter.IsLessThan}"
                                                             Margin="0,0,6,0">
                                                    <TextBlock Text="&lt;"
                                                               FontSize="16"
                                                               VerticalAlignment="Center"/>
                                                </RadioButton>

                                                <RadioButton GroupName="FilterOperator"
                                                             IsChecked="{Binding NetworkEntities.Filter.IsEqual}"
                                                             Margin="0,0,6,0">
                                                    <TextBlock Text="="
                                                               FontSize="16"
                                                               VerticalAlignment="Center"/>
                                                </RadioButton>

                                                <RadioButton GroupName="FilterOperator"
                                                             IsChecked="{Binding NetworkEntities.Filter.IsGreaterThan}">
                                                    <TextBlock Text="&gt;"
                                                               FontSize="16"
                                                               VerticalAlignment="Center"/>
                                                </RadioButton>
                                            </StackPanel>

                                            <TextBox Grid.Column="5"
                                                     Text="{Binding NetworkEntities.Filter.IdValue, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalAlignment="Stretch"/>
                                        </Grid>

                                        <CheckBox Grid.Row="2"
                                                  IsChecked="{Binding NetworkEntities.Filter.CombineTypeAndId}"
                                                  VerticalAlignment="Center">
                                            <TextBlock Text="Combine type + ID"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"/>
                                        </CheckBox>

                                        <Grid Grid.Row="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Filter preset:"
                                                       FontWeight="SemiBold"
                                                       FontSize="18"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,14,0"/>

                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding NetworkEntities.SavedFilters}"
                                                      DisplayMemberPath="Name"
                                                      SelectedItem="{Binding NetworkEntities.SelectedSavedFilter}"/>
                                        </Grid>

                                        <Grid Grid.Row="4">
                                            <Button Command="{Binding NetworkEntities.SaveFilterCommand}"
                                                    HorizontalAlignment="Left"
                                                    MinWidth="120"
                                                    Height="31">
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="▣"
                                                               FontSize="15"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,4,0"/>
                                                    <TextBlock Text="Save preset"
                                                               FontSize="16"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Command="{Binding NetworkEntities.ClearFiltersCommand}"
                                                    HorizontalAlignment="Right"
                                                    MinWidth="120"
                                                    Height="31">
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center">
                                                    <TextBlock Text="⌫"
                                                               FontSize="15"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,4,0"/>
                                                    <TextBlock Text="Clear filters"
                                                               FontSize="16"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="⌁"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                    <TextBlock Text="Network Graph"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>
                                    <TextBlock  Text="CTRL + 2"
                                                FontSize="10"
                                                VerticalAlignment="Center"
                                                TextAlignment="Center"
                                                Margin="0,4,0,0"/>
                                </StackPanel>
                            </TabItem.Header>

                            <Grid Margin="25,13,25,22">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="43"/>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="55"/>
                                    <RowDefinition Height="380"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <TextBlock Text="▱"
                                               FontSize="23"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="ENTITY GRAPH VIEW"
                                               FontWeight="SemiBold"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Choose entity:"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding MeasurementGraph.Entities}"
                                              DisplayMemberPath="Name"
                                              SelectedItem="{Binding MeasurementGraph.SelectedEntity}"/>
                                </Grid>

                                <TextBlock Grid.Row="2"
                                           Text="Last 5 measurements:"
                                           FontSize="18"
                                           VerticalAlignment="Center"/>

                                <Border Grid.Row="3" Background="Transparent">
                                    <Canvas>
                                        <Line X1="0"
                                              Y1="305"
                                              X2="500"
                                              Y2="305"
                                              Stroke="#222222"
                                              StrokeThickness="2"/>
                                        <Line X1="500"
                                              Y1="305"
                                              X2="490"
                                              Y2="297"
                                              Stroke="#222222"
                                              StrokeThickness="1"/>
                                        <Line X1="500"
                                              Y1="305"
                                              X2="490"
                                              Y2="313"
                                              Stroke="#222222"
                                              StrokeThickness="1"/>
                                        <TextBlock Text="time"
                                                   Canvas.Left="472"
                                                   Canvas.Top="276"
                                                   Foreground="#555555"
                                                   FontSize="14"/>
                                        <Line X1="0"
                                              Y1="125"
                                              X2="500"
                                              Y2="125"
                                              Stroke="#999999"
                                              StrokeThickness="1"
                                              StrokeDashArray="5 5"/>

                                        <ItemsControl ItemsSource="{Binding MeasurementGraph.LastMeasurements}"
                                                      ItemTemplate="{StaticResource GraphPointTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </Canvas>
                                </Border>

                                <StackPanel Grid.Row="4"
                                            VerticalAlignment="Bottom"
                                            Margin="5,0,0,8">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Ellipse Width="18"
                                                 Height="18"
                                                 Stroke="#555555"
                                                 Fill="#E5E5E5"
                                                 Margin="0,0,12,0"/>
                                        <TextBlock Text="Value that is valid (in accepted range)"
                                                   FontSize="17"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="18"
                                                 Height="18"
                                                 Stroke="#555555"
                                                 Fill="#999999"
                                                 Margin="0,0,12,0"/>
                                        <TextBlock Text="Value that is not valid (out of range)"
                                                   FontSize="17"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>